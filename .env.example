# Database
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=db_parklife
DB_USERNAME=root
DB_PASSWORD=

# Web: set false to build CSV only (no SFTP). CLI upload_sales.php respects this too.
UPLOAD_ENABLED=true

# Web only: limit rows when testing export/upload
LIMIT_COLLECT=false

# SFTP (required for upload when UPLOAD_ENABLED=true)
SFTP_HOST=example.com
SFTP_PORT=22
SFTP_USER=
SFTP_PASSWORD=
# Folder on the server (relative to SFTP login home), no leading slash
SFTP_REMOTE_DIR=uploads

# SFTP target for sales with NULL invoice_id
SFTP_NO_INVOICE_HOST=example.com
SFTP_NO_INVOICE_PORT=22
SFTP_NO_INVOICE_USER=
SFTP_NO_INVOICE_PASSWORD=
# Fill this folder later when available
SFTP_NO_INVOICE_REMOTE_DIR=
