<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>QUINOS - Sign in</title>
    <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-slate-100 min-h-screen flex items-center justify-center">
    <div class="bg-white rounded-2xl shadow-sm p-10 w-full max-w-md">
        <h1 class="text-2xl font-bold text-slate-800 mb-8">Sign in</h1>

        {% if error %}
        <p class="text-red-500 text-sm mb-4">{{ error }}</p>
        {% endif %}

        <form method="POST" action="/login">
            <div class="mb-5">
                <label class="block text-sm text-slate-600 mb-2">Name</label>
                <input type="text" name="name" required
                    class="w-full px-4 py-3 rounded-xl bg-slate-50 border border-slate-200 focus:outline-none focus:border-sky-400 text-slate-700">
            </div>

            <div class="mb-8">
                <label class="block text-sm text-slate-600 mb-2">PIN</label>
                <input type="password" name="pin" required
                    class="w-full px-4 py-3 rounded-xl bg-slate-50 border border-slate-200 focus:outline-none focus:border-sky-400 text-slate-700">
            </div>

            <button type="submit"
                class="w-full py-3 bg-sky-600 hover:bg-sky-700 text-white font-medium rounded-full transition">
                Sign in
            </button>
        </form>
    </div>
</body>
</html>
